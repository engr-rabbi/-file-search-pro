{
  "name": "file-search-pro",
  "version": "1.0.0",
  "description": "Professional local file search & indexing desktop app (Everything-style) with content search, filters, duplicate detection, disk analyzer and OCR search.",
  "main": "src/main/main.js",
  "author": "You",
  "license": "MIT",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-builder install-app-deps",
    "pack": "electron-builder --dir",
    "build": "electron-builder",
    "build:win": "electron-builder --win --x64",
    "build:portable": "electron-builder --win portable"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "chokidar": "^3.6.0",
    "electron-store": "^8.2.0",
    "fast-glob": "^3.3.3",
    "fuse.js": "^7.5.0",
    "mammoth": "^1.12.0",
    "pdf-parse": "^1.1.1",
    "tesseract.js": "^5.1.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.yourcompany.filesearchpro",
    "productName": "File Search Pro",
    "copyright": "Copyright © 2026",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "package.json",
      "!**/*.map"
    ],
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**",
      "**/node_modules/tesseract.js/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "File Search Pro"
    },
    "portable": {
      "artifactName": "FileSearchPro-Portable-${version}.exe"
    }
  }
}
